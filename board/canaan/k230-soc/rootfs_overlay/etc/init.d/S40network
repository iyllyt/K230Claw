#!/bin/sh
#
# Start the network....
#

# Debian ifupdown needs the /run/network lock directory
mkdir -p /run/network

case "$1" in
  start)
	printf "Starting network: "
	if [ -e /sys/class/net/eth0 ] ;then  ifup eth0 ;
	elif [ -e /sys/class/net/wlan0 ] ;then  ifup wlan0; fi;
	/sbin/ifup -a
	# Disable WiFi power saving to prevent RTL8189FTV LPS deadlock
	[ -e /sys/class/net/wlan0 ] && iwconfig wlan0 power off 2>/dev/null
	[ $? = 0 ] && echo "OK" || echo "FAIL"
	;;
  stop)
	printf "Stopping network: "
	[ -e /sys/class/net/wlan0 ] && ifdown wlan0
	[ -e /sys/class/net/eth0 ] && ifdown eth0
	/sbin/ifdown -a
	[ $? = 0 ] && echo "OK" || echo "FAIL"
	;;
  restart|reload)
	"$0" stop
	"$0" start
	;;
  *)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
esac

exit $?
